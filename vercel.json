{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), serial=(), interest-cohort=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; img-src 'self' data:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; media-src 'self'; font-src 'self'; connect-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.jpg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.mp4",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/.env", "destination": "/404.html", "statusCode": 404 },
    { "source": "/.env.:path*", "destination": "/404.html", "statusCode": 404 },
    { "source": "/.git/:path*", "destination": "/404.html", "statusCode": 404 },
    { "source": "/wp-admin/:path*", "destination": "/404.html", "statusCode": 404 },
    { "source": "/wp-login.php", "destination": "/404.html", "statusCode": 404 },
    { "source": "/wp-config.php", "destination": "/404.html", "statusCode": 404 },
    { "source": "/phpMyAdmin/:path*", "destination": "/404.html", "statusCode": 404 },
    { "source": "/phpmyadmin/:path*", "destination": "/404.html", "statusCode": 404 },
    { "source": "/xmlrpc.php", "destination": "/404.html", "statusCode": 404 },
    { "source": "/config/:path*", "destination": "/404.html", "statusCode": 404 },
    { "source": "/admin/:path*", "destination": "/404.html", "statusCode": 404 },
    { "source": "/api/:path*", "destination": "/404.html", "statusCode": 404 }
  ]
}
